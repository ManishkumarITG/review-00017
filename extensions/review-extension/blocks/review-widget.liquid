{{ 'review.css' | asset_url | stylesheet_tag }}
<script src="{{ 'starDesigns.js' | asset_url }}" defer></script>
<script src="{{ 'review.js' | asset_url }}" defer></script>

{% if customer == null and request.design_mode == false %}
  <script>
    window.location.replace('/account/login?return_to={{ request.path | url_encode }}');
  </script>
{% endif %}

<script>
  window.reviewSettings = {
    showDate: {{ block.settings.show_date }},
    reviewSource: "{{ block.settings.review_source }}"
  };
  {% if product %}
    window.__productId = {{ product.id | json }};
  {% endif %}
</script>

<script src="{{ 'reviewFilter.js' | asset_url }}" defer></script>

<div class="jm-review-widget my-review-widget" id="jm-review-{{ section.id }}">
  <div class="jm-list">
    {% if request.design_mode %}
      {% comment %} ---- Theme editor preview (static sample) ---- {% endcomment %}
      <div class="jm-header-area">
        <h2 class="jm-heading" data-setting="Widget title">Customer Reviews</h2>

        {% if block.settings.review_source == 'noReview' %}
          <div class="jm-Stars-Progressbar">
            <span class="jm-star-empty mainFontSize">
              {% for i in (1..5) %}
                <svg width="18" height="18" viewBox="0 0 24 24">
                  <path d="M12 2L15 9H22L17 14L19 22L12 18L5 22L7 14L2 9H9L12 2Z" fill="none" stroke="currentColor" stroke-width="1.5"></path>
                </svg>
              {% endfor %}
            </span>
          </div>
          <span class="jm-empty-state">Be the first to write a review</span>
        {% else %}
          <div class="center">
            <span class="star mainFontSize">
              {% for i in (1..4) %}
                <svg width="18" height="18" viewBox="0 0 24 24">
                  <path d="M12 2L15 9H22L17 14L19 22L12 18L5 22L7 14L2 9H9L12 2Z" fill="currentColor"></path>
                </svg>
              {% endfor %}
              <svg width="18" height="18" viewBox="0 0 24 24">
                <path d="M12 2L15 9H22L17 14L19 22L12 18L5 22L7 14L2 9H9L12 2Z" fill="none" stroke="currentColor" stroke-width="1.5"></path>
              </svg>
            </span>
            4.2 out of 5
          </div>
          <p class="jm-based center">Based on 5 reviews</p>

          {% assign sample_counts = '3,1,1,0,0' | split: ',' %}
          {% for count in sample_counts %}
            {% assign filled = 5 | minus: forloop.index0 %}
            <div class="jm-Stars-Progressbar">
              <span class="star mainFontSize">
                {% for i in (1..5) %}
                  {% if i <= filled %}
                    <svg width="18" height="18" viewBox="0 0 24 24">
                      <path d="M12 2L15 9H22L17 14L19 22L12 18L5 22L7 14L2 9H9L12 2Z" fill="currentColor"></path>
                    </svg>
                  {% else %}
                    <svg class="jm-star-empty" width="18" height="18" viewBox="0 0 24 24">
                      <path d="M12 2L15 9H22L17 14L19 22L12 18L5 22L7 14L2 9H9L12 2Z" fill="none" stroke="currentColor" stroke-width="1.5"></path>
                    </svg>
                  {% endif %}
                {% endfor %}
              </span>
              <div class="jm-progress-track">
                {% assign pct = count | times: 20 %}
                <div class="progressbar" style="width: {{ pct }}%;"></div>
              </div>
              <span class="jm-progress-count">{{ count }}</span>
            </div>
          {% endfor %}
        {% endif %}
      </div>

      <div class="jm-actions">
        <button class="jm-write button buttonText disablebutton">Write a review</button>

        {% unless block.settings.review_source == 'noReview' %}
          <div class="jm-sort">
            <select class="jm-sort-select star">
              <option value="most_recent">Most Recent</option>
              <option value="highest">Highest Rating</option>
              <option value="lowest">Lowest Rating</option>
            </select>
          </div>

          {% if block.settings.review_source == 'dummy' %}
            <div id="reviewsContainer" style="width: 100%; margin-top: 20px; display: flex; flex-direction: column; gap: var(--jm-card-gap);">
              {% assign sample_names = 'Arjun,Meera,Jason' | split: ',' %}
              {% assign sample_ratings = '5,4,3' | split: ',' %}
              {% assign sample_texts = 'Product quality is amazing!,Pretty solid value for money.,Decent but packaging could be better.' | split: ',' %}
              {% for name in sample_names %}
                <div class="jm-review-card">
                  <div class="jm-avatar">{{ name | slice: 0 }}</div>
                  <div class="jm-card-body">
                    <div class="jm-card-topline">
                      <span class="star mainFontSize" style="justify-content: start;">
                        {% assign r = sample_ratings[forloop.index0] | plus: 0 %}
                        {% for i in (1..5) %}
                          {% if i <= r %}
                            <svg width="18" height="18" viewBox="0 0 24 24">
                              <path d="M12 2L15 9H22L17 14L19 22L12 18L5 22L7 14L2 9H9L12 2Z" fill="currentColor"></path>
                            </svg>
                          {% else %}
                            <svg class="jm-star-empty" width="18" height="18" viewBox="0 0 24 24">
                              <path d="M12 2L15 9H22L17 14L19 22L12 18L5 22L7 14L2 9H9L12 2Z" fill="none" stroke="currentColor" stroke-width="1.5"></path>
                            </svg>
                          {% endif %}
                        {% endfor %}
                      </span>
                      {% if block.settings.show_date %}
                        <p class="jm-secondary-text">2025-01-0{{ forloop.index }}</p>
                      {% endif %}
                    </div>
                    <p class="tagName">{{ name }}</p>
                    <p class="jm-review-body">{{ sample_texts[forloop.index0] }}</p>
                  </div>
                </div>
              {% endfor %}
            </div>
          {% endif %}
        {% endunless %}
      </div>
    {% else %}
      {% comment %} ---- Live storefront: skeleton filled by reviewFilter.js ---- {% endcomment %}
      <div class="jm-header-area">
        <h2 class="jm-heading" data-setting="Widget title">Customer Reviews</h2>
        <div class="costomeSummary"></div>
      </div>
      <div class="jm-actions">
        <button class="jm-write button buttonText disablebutton">Write a review</button>

        <div class="jm-sort">
          <select class="jm-sort-select star">
            <option value="most_recent">Most Recent</option>
            <option value="highest">Highest Rating</option>
            <option value="lowest">Lowest Rating</option>
          </select>
        </div>

        <div id="reviewsList"></div>
      </div>
    {% endif %}
  </div>

  <div id="FormParentDiv" class="modal-overlay" style="display:none">
    <div id="popupForm" class="modal-overlay">
      <form id="reviewForm" class="review-card">
        <div id="closeForm" class="close-btn" onclick="closeForm()">
          <svg
            xmlns="http://www.w3.org/2000/svg"
            width="26"
            height="26"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2.5"
            stroke-linecap="round"
            stroke-linejoin="round"
          >
            <line x1="18" y1="6" x2="6" y2="18"/>
            <line x1="6" y1="6" x2="18" y2="18"/>
          </svg>
        </div>

        <div class="jm-form-head">
          <h3 class="jm-form-title" data-setting="Screen title">How would you rate this product?</h3>
          <p class="jm-form-intro" data-setting="Introduction">We would love it if you would share a bit about your experience.</p>
        </div>

        <!-- Rating -->
        <label class="field-label">
          Rate the product
          <div id="formStars" class="star-wrapper">
            <div
              class="ReviewFormRating"
              style="display: flex; align-items: center; justify-content: center;"
              id="ratingStars"
            >
              {% for i in (1..5) %}
                <span class="form-star" data-value="{{ i }}">
                  <svg width="1em" height="1em" viewBox="0 0 24 24" aria-hidden="true" focusable="false"><path d="M15.791,19.5,10.262,16.6,4.732,19.5a.75.75,0,0,1-1.088-.79L4.7,12.557.228,8.2a.75.75,0,0,1,.415-1.28l6.182-.9L9.589.419a.75.75,0,0,1,1.345,0l2.764,5.6,6.182.9A.751.751,0,0,1,20.3,8.2l-4.473,4.36,1.056,6.157a.748.748,0,0,1-1.088.79Z" transform="translate(1.739 1.25)" fill="currentColor"></path></svg>
                </span>
              {% endfor %}
            </div>
            <input type="hidden" id="selectedRating" name="Rating" value="0">
            <span class="error-msg"></span>
          </div>
        </label>

        <!-- Name -->
        <label class="field-label">
          Display Name
          <input
            name="Name"
            type="text"
            placeholder="Enter Your Name"
            class="input-field"
            id="formName"
          >
          <span class="error-msg"></span>
        </label>

        <!-- Email -->
        <label class="field-label">
          Email
          <input
            name="Email"
            type="text"
            placeholder="Enter Your Email"
            class="input-field"
            id="formEmail"
          >
          <span class="error-msg"></span>
        </label>

        <!-- Description -->
        <label class="field-label">
          Description
          <textarea
            name="Discription"
            placeholder="Write your review here ... "
            class="textarea-field"
            id="formDesc"
          ></textarea>
          <span class="error-msg"></span>
        </label>

        <button type="submit" class="submit-btn button jm-write" id="submitButton">Submit</button>
      </form>
    </div>
  </div>
</div>
{% schema %}
{
  "name": "ReviewWidget",
  "target": "section",

  "settings": [
    {
      "type": "select",
      "id": "review_source",
      "label": "Editor Preview",
      "default": "dummy",
      "options": [
        {
          "value": "dummy",
          "label": "Sample Data"
        },
        {
          "value": "real",
          "label": "Summary Only"
        },
        {
          "value": "noReview",
          "label": "No Review"
        }
      ]
    },

    {
      "type": "checkbox",
      "id": "show_date",
      "label": "Show Date",
      "default": false
    }
  ]
}
{% endschema %}
