{{ 'review.css' | asset_url | stylesheet_tag }}
<script src="{{ 'review.js' | asset_url }}" defer>
  const productId = {{ product.id | json }};
</script>

{% if customer == null and request.design_mode == false %}
  <script>
    window.location.replace('/account/login?return_to={{ request.path | url_encode }}');
  </script>
{% endif %}

<script>
  window.reviewSettings = {
    starColor: "{{ block.settings.star_color }}",
    textColor: "{{ block.settings.text_color }}",
    showDate: {{ block.settings.show_date }},
    reviewSource: "{{ block.settings.review_source }}"
  };
</script>

<script src="{{ 'reviewFilter.js' | asset_url }}" defer></script>
<script src="{{ 'reviewSetting.js' | asset_url }}" defer></script>

{% if product %}
  <script>
    window.__productId = {{ product.id | json }};
    console.log("Product ID from Liquid:", window.__productId);
  </script>
{% endif %}

{% assign actual_rating = block.settings.actual_rating %}

<div class="jm-review-widget my-review-widget" id="jm-review-{{ section.id }}">
  {% comment %} <!-- Header --> {% endcomment %}

  <div class="jm-list" style="    padding: 0px 72px;" d="jm-list-{{ section.id }}">
    {% if block.settings.review_source == 'dummy' %}
      <div
        style="
          display: flex;
          flex-direction: column;
          align-items: center;
          gap: 9px;
        "
      >
        <h2
          class="jm-heading"
          style="
            color: black;
            font-size: 22px;
          "
        >
          Customer Reviews
        </h2>
        <div>
          <div style=" align-items:center; gap:0px; flex-direction:row;">
            <span
              style="
                color: {{block.settings.star_color}};
                {% comment %} font-size: {{block.settings.star_size}}px; {% endcomment %}
                display:flex;
                gap:8px;
                align-items:center;
              "
            >
              {% render 'stars', rating: actual_rating %}
              <span style="font-weight:normal; color:black; font-size:14px;">{{ actual_rating }} out of 5</span>
            </span>
          </div>
          <span>Based on 15 reviews</span>
        </div>
        <div>
          {% assign star_counts = '8,3,1,3,0' | split: ',' %}
          {% assign total_reviews = 0 %}
          {% for c in star_counts %}
            {% assign total_reviews = total_reviews | plus: c %}
          {% endfor %}
          {% for i in (1..5) reversed %}
            {% assign index = forloop.index0 %}
            {% assign count = star_counts[index] | plus: 0 %}
            {% if total_reviews > 0 %}
              {% assign progress_percent = count | times: 100.0 | divided_by: total_reviews %}
            {% else %}
              {% assign progress_percent = 0 %}
            {% endif %}
            <div class="jm-Stars-Progressbar">
              {% comment %} <!-- LEFT: static stars (5 to 1) --> {% endcomment %}
              <span
                style="
                  color: #388B7F;
                  font-size: 19px;
                  width: 40%;
                  display: flex
                "
              >
                {% render 'stars', rating: i %}
              </span>
              {% comment %} <!-- MIDDLE: progress bar --> {% endcomment %}
              <div style="background:#e5e7eb; height:14px; width:140px; border-radius:0px; overflow:hidden;">
                <div
                  style="
                    height:14px;
                    width:{{ progress_percent }}%;
                    background: #388B7F;
                    border-radius:0px;
                  "
                ></div>
              </div>
              {% comment %} <!-- RIGHT: count --> {% endcomment %}
              <span style="color:#888888;">
                {{ count }}
              </span>
            </div>
          {% endfor %}
        </div>
      </div>
      <div class="jm-actions">
        <button
          class="jm-write"
          style="
            background: #388B7F;
            color: white;
            margin: 10px 0;
            width: 100%;
          "
          {% comment %} onclick="handleClick()" {% endcomment %}
        >
          Write a review
        </button>

        <div class="jm-sort">
          <select
            class="jm-sort-select"
            id="{{ block.settings.RatingFilter  }}"
            style="color:{{block.settings.star_color}}"
          >
            <option value="most_recent">Most Recent</option>
            <option value="highest">Highest Rating</option>
            <option value="lowest">Lowest Rating</option>
          </select>
        </div>
      </div>

      <div
        id="reviewsList"
        style="display:flex; flex-direction:column; gap:18px; margin-top:20px;     position: relative;"
      ></div>
    {% elsif block.settings.review_source == 'real' %}
      <div
        style="
          display: flex;
          flex-direction: column;
          align-items: center;
          gap: 9px;
        "
      >
        <h2
          class="jm-heading"
          style="
            color: black;
            font-size: 22px;
          "
        >
          Customer Reviews
        </h2>
        <div>
          <div style=" align-items:center; gap:0px; flex-direction:row;">
            <span
              style="
                color : #108474;
                font-size: 19px;
                display:flex;
                gap:8px;
                align-items:center;
              "
            >
              {% render 'stars', rating: actual_rating %}
              <span style="font-weight:normal; color:black; font-size:16px;">{{ actual_rating }} out of 5</span>
            </span>
          </div>
          <span
            style="
              font-weight: normal;
              color: black;
              font-size: 16px;
            "
            >Based on 15 reviews</span
          >
        </div>
        <div>
          {% assign star_counts = '8,3,1,3,0' | split: ',' %}
          {% assign total_reviews = 0 %}
          {% for c in star_counts %}
            {% assign total_reviews = total_reviews | plus: c %}
          {% endfor %}
          {% for i in (1..5) reversed %}
            {% assign index = forloop.index0 %}
            {% assign count = star_counts[index] | plus: 0 %}
            {% if total_reviews > 0 %}
              {% assign progress_percent = count | times: 100.0 | divided_by: total_reviews %}
            {% else %}
              {% assign progress_percent = 0 %}
            {% endif %}
            <div class="jm-Stars-Progressbar">
              {% comment %} <!-- LEFT: static stars (5 to 1) --> {% endcomment %}
              <span
                style="
                  color: #388B7F;
                  font-size: 19px;
                  width: 40%;
                  display: flex
                "
              >
                {% render 'stars', rating: i %}
              </span>
              {% comment %} <!-- MIDDLE: progress bar --> {% endcomment %}
              <div style="background:#e5e7eb; height:14px; width:140px; border-radius:0px; overflow:hidden;">
                <div
                  style="
                    height:14px;
                    width:{{ progress_percent }}%;
                    background: #388B7F;
                    border-radius:0px;
                  "
                ></div>
              </div>
              {% comment %} <!-- RIGHT: count --> {% endcomment %}
              <span style="color:#888888;">
                {{ count }}
              </span>
            </div>
          {% endfor %}
        </div>
      </div>
      <div class="jm-actions">
        <button
          class="jm-write"
          style="
            background: #388B7F;
            color: white;
            margin: 10px 0;
            width: 100%;
          "
          {% comment %} onclick="handleClick()" {% endcomment %}
        >
          Write a review
        </button>

        <div class="jm-sort">
          <select class="jm-sort-select" style="color:{{block.settings.star_color}}">
            <option value="most_recent">Most Recent</option>
            <option value="highest">Highest Rating</option>
            <option value="lowest">Lowest Rating</option>
          </select>
        </div>
      </div>
      <div
        id="reviewsList"
        style="display:flex; flex-direction:column; gap:18px; margin-top:20px;     position: relative; "
      ></div>

    {% elsif block.settings.review_source == 'noReview' %}
      <div
        style="
                    display: flex;
          flex-direction: column;
          align-items: center;
          gap: 33px;
        "
      >
        <div>
          <h2
            class="jm-heading"
            style="
              color:black;
              font-size: 21px;
            "
          >
            Customer Reviews
          </h2>
        </div>
        <div
          style="
            display: flex;
            justify-content: center;
            gap: 50px;
            align-items: center;
          "
        >
          <div
            style="
                     display: flex;
              align-items: self-start;
              flex-direction: column;
            "
          >
            <div>
              {% for i in (1..5) %}
                <span
                  class="form-star"
                  style="
                    font-size:20px;
                    color:#ccc;
                    cursor:pointer;
                  "
                  >★</span
                >
              {% endfor %}
            </div>
            <span>Be the first to write a review</span>
          </div>

          <div>
            <button
              class="jm-write"
              style="
                background: #388B7F;
                color: white;
              "
              {% comment %} onclick="handleClick()" {% endcomment %}
            >
              Write a review
            </button>
          </div>
        </div>
      </div>

    {% else %}
      {% comment %} <!-- Fallback (only if some wild unknown value appears) --> {% endcomment %}
      <div class="jm-db-placeholder">
        <span
          style="
            color: {{block.settings.star_color}};
            font-size: {{block.settings.star_size}}px;
          "
        >
          {% render 'stars', rating: 5 %}
        </span>
        <button
          class="jm-write"
          style="
            background: #388B7F;
            color: white;
          "
          {% comment %} onclick="handleClick()" {% endcomment %}
        >
          Write a review
        </button>
      </div>
    {% endif %}
  </div>
  <div id="FormParentDiv" class="modal-overlay" style="display:none">
    <div id="popupForm" class="modal-overlay">
      <form id="reviewForm" class="review-card">
        <div id="closeForm" class="close-btn" onclick="closeForm()">
          <svg
            xmlns="http://www.w3.org/2000/svg"
            width="26"
            height="26"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2.5"
            stroke-linecap="round"
            stroke-linejoin="round"
          >
            <line x1="18" y1="6" x2="6" y2="18"/>
            <line x1="6"  y1="6" x2="18" y2="18"/>
          </svg>
        </div>

        <!-- Rating -->
        <label class="field-label">
          Rate the product
          <div id="formStars" class="star-wrapper">
            <div
              style="
                display: flex;
                align-items: center;
                justify-content: center;
              "
            >
              {% for i in (1..5) %}
                <span class="form-star" data-value="{{ i }}">★</span>
              {% endfor %}
            </div>
            <input type="hidden" id="selectedRating" name="Rating" value="0">
            <span class="error-msg"></span>
          </div>
        </label>

        <!-- Name -->
        <label class="field-label">
          Display Name
          <input
            name="Name"
            type="text"
            placeholder="Enter Your Name"
            value="{{ block.settings.display_name_text }}"
            class="input-field"
            id="formName"
          >
          <span class="error-msg"></span>
        </label>

        <!-- Email -->
        <label class="field-label">
          Email
          <input
            name="Email"
            type="text"
            placeholder="Enter Your Email"
            value="{{ block.settings.User_email }}"
            class="input-field"
            id="formEmail"
          >
          <span class="error-msg"></span>
        </label>

        <!-- Description -->
        <label class="field-label">
          Description
          <textarea
            name="Discription"
            placeholder="Write your review here ... "
            class="textarea-field"
            id="formDesc"
          >{{ block.settings.textarea_text }}</textarea>
          <span class="error-msg"></span>
        </label>

        <button type="submit" class="submit-btn" id="submitButton">Submit</button>
      </form>
    </div>
  </div>
</div>
{% schema %}
{
  "name": "ReviewWidget",
  "target": "section",

  "settings": [
    {
      "type": "select",
      "id": "review_source",
      "label": "Review Source",
      "default": "dummy",
      "options": [
        {
          "value": "dummy",
          "label": "sample Data"
        },
        {
          "value": "real",
          "label": "Real Data"
        },
        {
          "value": "noReview",
          "label": "No Review"
        }
      ]
    },

    {
      "type": "checkbox",
      "id": "show_date",
      "label": "Show Date",
      "default": false
    },
    {
      "type": "text",
      "id": "textarea_text",
      "label": "Textarea Placeholder"
    },

    {
      "type": "text",
      "id": "display_name_text",
      "label": "Display name placeholder"
    },
    {
      "type": "text",
      "id": "User_email",
      "label": "Email text "
    }
  ]
}
{% endschema %}
