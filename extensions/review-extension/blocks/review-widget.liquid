{{ 'review.css' | asset_url | stylesheet_tag }}
<script src="{{ 'review.js' | asset_url }}" defer>
  const productId = {{ product.id | json }};
</script>

{% if customer == null and request.design_mode == false %}
  <script>
    console.log(request.design_mode);
    window.location.replace('/account/login?return_to={{ request.path | url_encode }}');
  </script>
{% endif %}

<script>
  window.reviewSettings = {
    starColor: "{{ block.settings.star_color }}",
    textColor: "{{ block.settings.text_color }}",
    showDate: {{ block.settings.show_date }},
    reviewSource: "{{ block.settings.review_source }}"
  };
</script>

<script src="{{ 'reviewFilter.js' | asset_url }}" defer></script>
<script src="{{ 'starratting.js' | asset_url }}" defer></script>

{% if product %}
  <script>
    window.__productId = {{ product.id | json }};
    console.log("Product ID from Liquid:", window.__productId);
  </script>
{% endif %}

{% comment %} {% assign actual_rating = block.settings.actual_rating %} {% endcomment %}

<div class="jm-review-widget my-review-widget" id="jm-review-{{ section.id }}">
  {% comment %} <!-- Header --> {% endcomment %}

  <div class="jm-list" style="padding: 0px 72px;" d="jm-list-{{ section.id }}">
    {% if  request.design_mode == true%}
    {% if block.settings.review_source == 'dummy' %}
     
 <div
        style="
          display: flex;
          flex-direction: column;
          align-items: center;
          gap: 33px;
        "
      >
        <div>
          <h2
            class="jm-heading"
            style="
              color:black;
              font-size: 21px;
            "
            data-setting="Widget title"
          >
            Customer Reviews
          </h2>
        </div>
        <div
          style="
            display: flex;
            flex-direction: column;
            justify-content: center;
            gap: 50px;
            align-items: center;
          "
        >
          <div
            style="
              display: flex;
              align-items: center;
              justify-content: center;
              flex-direction: column;
            "
          >
            <div>
              {% for i in (1..5) %}
                <span
                  class="form-star star"
                  style="
                    font-size:20px;
                    color:#ccc;
                    cursor:pointer;
                    text-align:center
                  "
                  >★</span
                >
              {% endfor %}
            </div>
            <span>Based on 3 reviews</span>
          </div>

          <div>
            <button
              class="jm-write button"
              style="
                background: #388B7F;
                color: white;
              "
            >
              Write a review
            </button>
          </div>
        </div>
      </div>


    {% elsif block.settings.review_source == 'real' %}
       <div
        style="
                    display: flex;
          flex-direction: column;
          align-items: center;
          gap: 33px;
        "
      >
        <div>
          <h2
            class="jm-heading"
            style="
              color:black;
              font-size: 21px;
            "
            data-setting="Widget title"
          >
            Customer Reviews
          </h2>
        </div>
        <div
          style="
            display: flex;
            justify-content: center;
            gap: 50px;
            align-items: center;
          "
        >
          <div
            style="
                     display: flex;
              align-items: self-start;
              flex-direction: column;
            "
          >
            <div>
              {% for i in (1..5) %}
                <span
                  class="form-star star"
                  style="
                    font-size:20px;
                    color:#ccc;
                    cursor:pointer;
                  "
                  >★</span
                >
              {% endfor %}
            </div>
            <span>Be the first to write a review</span>
          </div>

          <div>
            <button
              class="jm-write button"
              style="
                background: #388B7F;
                color: white;
              "
              {% comment %} onclick="handleClick()" {% endcomment %}
            >
              Write a review
            </button>
          </div>
        </div>
      </div>


    {% elsif block.settings.review_source == 'noReview' %}
      <div class="jm-db-placeholder">
        <span
          style="
            color: {{block.settings.star_color}};
            font-size: {{block.settings.star_size}}px;
          "
          class="star"
        >
          {% render 'stars', rating: 5 %}
        </span>
        <button
          class="jm-write button disablebutton"
          style="
            background: #388B7F;
            color: white;
          "
          {% comment %} onclick="handleClick()" {% endcomment %}
        >
          Write a review
        </button>
      </div>

     <div
        style="
                    display: flex;
          flex-direction: column;
          align-items: center;
          gap: 33px;
        "
      >
        <div>
          <h2
            class="jm-heading"
            style="
              color:black;
              font-size: 21px;
            "
            data-setting="Widget title"
          >
            Customer Reviews
          </h2>
        </div>
        <div
          style="
            display: flex;
            justify-content: center;
            gap: 50px;
            align-items: center;
          "
        >
          <div
            style="
                     display: flex;
              align-items: self-start;
              flex-direction: column;
            "
          >
            <div>
              {% for i in (1..5) %}
                <span
                  class="form-star star"
                  style="
                    font-size:20px;
                    color:#ccc;
                    cursor:pointer;
                  "
                  >★</span
                >
              {% endfor %}
            </div>
            <span>Be the first to write a review</span>
          </div>

          <div>
            <button
              class="jm-write button"
              style="
                background: #388B7F;
                color: white;
              "
              {% comment %} onclick="handleClick()" {% endcomment %}
            >
              Write a review
            </button>
          </div>
        </div>
      </div>

    {% endif %}
    {% endif %}
    <div class="costomeSummary"></div>
  </div>
  <div id="FormParentDiv" class="modal-overlay" style="display:none">
    <div id="popupForm" class="modal-overlay">
      <form id="reviewForm" class="review-card">
        <div id="closeForm" class="close-btn" onclick="closeForm()">
          <svg
            xmlns="http://www.w3.org/2000/svg"
            width="26"
            height="26"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2.5"
            stroke-linecap="round"
            stroke-linejoin="round"
          >
            <line x1="18" y1="6" x2="6" y2="18"/>
            <line x1="6"  y1="6" x2="18" y2="18"/>
          </svg>
        </div>

        <!-- Rating -->
        <label class="field-label">
          Rate the product
          <div id="formStars" class="star-wrapper">
            <div
              style="
                display: flex;
                align-items: center;
                justify-content: center;
              "
            >
              {% for i in (1..5) %}
                <span class="form-star " data-value="{{ i }}">★</span>
              {% endfor %}
            </div>
            <input type="hidden" id="selectedRating" name="Rating" value="0">
            <span class="error-msg"></span>
          </div>
        </label>

        <!-- Name -->
        <label class="field-label ">
          Display Name
          <input
            name="Name"
            type="text"
            placeholder="Enter Your Name"
            value="{{ block.settings.display_name_text }}"
            class="input-field"
            id="formName"
          >
          <span class="error-msg"></span>
        </label>

        <!-- Email -->
        <label class="field-label">
          Email
          <input
            name="Email"
            type="text"
            placeholder="Enter Your Email"
            value="{{ block.settings.User_email }}"
            class="input-field"
            id="formEmail"
          >
          <span class="error-msg"></span>
        </label>

        <!-- Description -->
        <label class="field-label">
          Description
          <textarea
            name="Discription"
            placeholder="Write your review here ... "
            class="textarea-field"
            id="formDesc"
          >{{ block.settings.textarea_text }}</textarea>
          <span class="error-msg"></span>
        </label>

        <button type="submit" class="submit-btn button jm-write" id="submitButton">Submit</button>
      </form>
    </div>
  </div>
</div>
{% schema %}
{
  "name": "ReviewWidget",
  "target": "section",

  "settings": [
    {
      "type": "select",
      "id": "review_source",
      "label": "Review Source",
      "default": "dummy",
      "options": [
        {
          "value": "dummy",
          "label": "sample Data"
        },
        {
          "value": "real",
          "label": "Real Data"
        },
        {
          "value": "noReview",
          "label": "No Review"
        }
      ]
    },

    {
      "type": "checkbox",
      "id": "show_date",
      "label": "Show Date",
      "default": false
    },
    {
      "type": "text",
      "id": "textarea_text",
      "label": "Textarea Placeholder"
    },

    {
      "type": "text",
      "id": "display_name_text",
      "label": "Display name placeholder"
    },
    {
      "type": "text",
      "id": "User_email",
      "label": "Email text "
    }
  ]
}
{% endschema %}





