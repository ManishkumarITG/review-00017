{{ 'review.css' | asset_url | stylesheet_tag }}
<script src="{{ 'review.js' | asset_url }}" defer>
  const productId = {{ product.id | json }};
</script>

{% if customer == null and request.design_mode == false %}
  <script>
    window.location.replace('/account/login?return_to={{ request.path | url_encode }}');
  </script>
{% endif %}

<script>
  window.reviewSettings = {
    starColor: "{{ block.settings.star_color }}",
    textColor: "{{ block.settings.text_color }}",
    showDate: {{ block.settings.show_date }},
    reviewSource: "{{ block.settings.review_source }}"
  };
</script>

<script src="{{ 'reviewFilter.js' | asset_url }}" defer></script>
{% comment %} <script src="{{ 'reviewSetting.js' | asset_url }}" defer></script> {% endcomment %}

{% if product %}
  <script>
    window.__productId = {{ product.id | json }};
    console.log("Product ID from Liquid:", window.__productId);
  </script>
{% endif %}

{% assign actual_rating = block.settings.actual_rating %}

<div class="jm-review-widget my-review-widget" id="jm-review-{{ section.id }}">
  {% comment %} <!-- Header --> {% endcomment %}

  <div class="jm-list" style="padding: 0px 72px;" d="jm-list-{{ section.id }}">
    {% if block.settings.review_source == 'dummy' %}
      <div
        style="
          display: flex;
          flex-direction: column;
          align-items: center;
          gap: 9px;
        "
      >
        <h2
          class="jm-heading"
          style="
            color: black;
            font-size: 22px;
          "
          data-setting="Widget title"
        >
          {% comment %} Customer Reviews {% endcomment %}
        </h2>
        <div>
          {% if request.design_mode == true %}
            <div style=" align-items:center; gap:0px; flex-direction:row;">
              <span
                style="
                  color: {{block.settings.star_color}};
                  {% comment %} font-size: {{block.settings.star_size}}px; {% endcomment %}
                  display:flex;
                  gap:8px;
                  align-items:center;
                "
              >
                {% render 'stars', rating: actual_rating %}
                <span style="font-weight:normal; color:black; font-size:14px;">{{ actual_rating }} out of 5</span>
              </span>
            </div>
            <span>Based on 15 reviews</span>
            
              <button
                class="jm-write button buttonText disablebutton 1"
                style="
                  background: #388B7F;
                  color: white;
                  margin: 10px 0;
                  width: 100%;
                "
                {% comment %} onclick="handleClick()" {% endcomment %}
              >
                {% comment %} Write a review {% endcomment %}
              </button>

              <div id="reviewsContainer"></div>

            <script>
              // -----------------------------
              // Dummy data (as requested)
              // -----------------------------
              const dummydata = [
                {
                  _id: '1',
                  author: 'Arjun',
                  rating: 5,
                  description: 'Bro product legit fire fr fr',
                  date: '2025-01-05',
                },
                {
                  _id: '2',
                  author: 'Meera',
                  rating: 4,
                  description: 'Pretty solid ngl, value for money',
                  date: '2025-11-26',
                },
                {
                  _id: '3',
                  author: 'Jason',
                  rating: 3,
                  description: 'Decent but packaging could’ve been better.',
                  date: '2024-12-22',
                },
                {
                  _id: '4',
                  author: 'Tanya',
                  rating: 2,
                  description: 'Not what I expected tbh.',
                  date: '2024-11-15',
                },
                {
                  _id: '5',
                  author: 'Kabir',
                  rating: 1,
                  description: 'Terrible quality, do not buy!',
                  date: '2024-10-30',
                },
              ];

              // -------------------------------------
              // Helper: Generate star HTML text
              // -------------------------------------
              function getStarArray(rating) {
                const totalStars = 5;
                let stars = [];

                for (let i = 1; i <= totalStars; i++) {
                  stars.push(i <= rating ? '★' : '☆');
                }

                return stars.join('');
              }

              // -------------------------------------
              // Avatar generator (first letter)
              // -------------------------------------
              function getAvatar(name) {
                const letter = name?.charAt(0)?.toUpperCase() || '?';
                return `<div style="
                                    width:40px; height:40px;
                                    display:flex; align-items:center; justify-content:center;
                                    border-radius:50%; background:#eee;
                                    font-weight:600;
                                    ">${letter}</div>`;
              }

              // -------------------------------------
              // Render dummy reviews inside container
              // -------------------------------------
              function renderDummyReviews() {
                const container = document.getElementById('reviewsContainer');
                container.innerHTML = ''; // reset

                dummydata.forEach((review) => {
                  const reviewItem = document.createElement('div');

                  const avatar = getAvatar(review.author);
                  const userName = review.author;

                  reviewItem.innerHTML = `
                              <div style="
                                display:flex; gap:14px; padding:16px;
                                box-shadow:0 2px 8px rgba(0,0,0,0.04);
                                border-radius:12px;
                                margin-bottom:16px;
                              ">
                                <div class="jm-avatar star" style="font-size:18px;">
                                  ${avatar}
                                </div>

                                <div style="flex:1; width:380px;">
                                  <div style="display:flex; justify-content:space-between; align-items:center;">
                                    <div>
                                      <div style="font-size:16px;" class="star">
                                        <span class="mainFontSize" style="justify-content:start">
                                          ${getStarArray(review.rating)}
                                        </span>
                                      </div>
                                      <p class="tagName" style="margin:0px;">
                                        ${userName}
                                      </p>
                                    </div>

                                    <div style="display:flex; align-items:center; gap:10px;" class="text">
                                      <p style="margin:0; color:#888;">
                                        ${review.date}
                                      </p>

                                      <!-- Edit icon (dummy always off) -->
                                    </div>
                                  </div>

                                  <p style="margin:0px;">
                                    ${review.description}
                                  </p>
                                </div>
                              </div>
                            `;

                  container.appendChild(reviewItem);
                });
              }

              // Fire render
              renderDummyReviews();
            </script>
          {% endif %}
        </div>
      </div>
      <div class="jm-actions">
        <div class="costomeSummary"></div>
        <button
          class="jm-write button buttonText disablebutton 2"
          style="
            background: #388B7F;
            color: white;
            margin: 10px 0;
            width: 100%;
          "
        >
          {% comment %} Write a review {% endcomment %}
        </button>

        <div class="jm-sort">
          <select class="jm-sort-select star">
            <option value="most_recent">Most Recent</option>
            <option value="highest">Highest Rating</option>
            <option value="lowest">Lowest Rating</option>
          </select>
        </div>
        <div
          id="reviewsList"
          style="display:flex; flex-direction:column; gap:18px; margin-top:20px; position: relative;"
        ></div>
      </div>

      <div
        id="reviewsList"
        style="display:flex; flex-direction:column; gap:18px; margin-top:20px; position: relative;"
      ></div>
    {% elsif block.settings.review_source == 'real' %}
      <div
        style="
          display: flex;
          flex-direction: column;
          align-items: center;
          gap: 9px;
        "
      >
        <h2
          class="jm-heading"
          style="
            color: black;
            font-size: 22px;
          "
          data-setting="Widget title"
        >
          {% comment %} Customer Reviews {% endcomment %}
        </h2>
        <div>
          <div style="align-items:center; gap:0px; flex-direction:row;">
            <div class="costomeSummary"></div>
          </div>
        </div>
      </div>
      <div class="jm-actions">
        <button
          class="jm-write button buttonText disablebutton 3"
          style="
            background: #388B7F;
            color: white;
            margin: 10px 0;
            width: 100%;
          "
          {% comment %} onclick="handleClick()" {% endcomment %}
        >
          {% comment %} Write a review {% endcomment %}
        </button>

        <div class="jm-sort">
          <select class="jm-sort-select star">
            <option value="most_recent">Most Recent</option>
            <option value="highest">Highest Rating</option>
            <option value="lowest">Lowest Rating</option>
          </select>
        </div>
      </div>
      <div
        id="reviewsList"
        style="display:flex; flex-direction:column; gap:18px; margin-top:20px;     position: relative; "
      ></div>

    {% elsif block.settings.review_source == 'noReview' %}
      <div
        style="
                    display: flex;
          flex-direction: column;
          align-items: center;
          gap: 33px;
        "
      >
        <div>
          <h2
            class="jm-heading"
            style="
              color:black;
              font-size: 21px;
            "
            data-setting="Widget title"
          >
            {% comment %} Customer Reviews {% endcomment %}
          </h2>
        </div>
        <div
          style="
            display: flex;
            justify-content: center;
            gap: 50px;
            align-items: center;
          "
        >
          <div
            style="
                     display: flex;
              align-items: self-start;
              flex-direction: column;
            "
          >
            <div>
              {% for i in (1..5) %}
                <span
                  class="form-star star"
                  style="
                    font-size:20px;
                    color:#ccc;
                    cursor:pointer;
                  "
                  >★</span
                >
              {% endfor %}
            </div>
            <span>Be the first to write a review</span>
          </div>

          <div>
            <button
              class="jm-write button buttonText disablebutton 4"
              style="
                background: #388B7F;
                color: white;
              "
              {% comment %} onclick="handleClick()" {% endcomment %}
            >
              {% comment %} Write a review {% endcomment %}
            </button>
          </div>
        </div>
      </div>

    {% else %}
      {% comment %} <!-- Fallback (only if some wild unknown value appears) --> {% endcomment %}
      <div class="jm-db-placeholder">
        <span
          style="
            color: {{block.settings.star_color}};
            font-size: {{block.settings.star_size}}px;
          "
          class="star"
        >
          {% render 'stars', rating: 5 %}
        </span>
        <button
          class="jm-write button buttonText disablebutton 5"
          style="
            background: #388B7F;
            color: white;
          "
          {% comment %} onclick="handleClick()" {% endcomment %}
        >
          {% comment %} Write a review {% endcomment %}
        </button>
      </div>
    {% endif %}
  </div>
  <div id="FormParentDiv" class="modal-overlay" style="display:none">
    <div id="popupForm" class="modal-overlay">
      <form id="reviewForm" class="review-card">
        <div id="closeForm" class="close-btn" onclick="closeForm()">
          <svg
            xmlns="http://www.w3.org/2000/svg"
            width="26"
            height="26"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2.5"
            stroke-linecap="round"
            stroke-linejoin="round"
          >
            <line x1="18" y1="6" x2="6" y2="18"/>
            <line x1="6"  y1="6" x2="18" y2="18"/>
          </svg>
        </div>

        <!-- Rating -->
        <label class="field-label">
          Rate the product
          <div id="formStars" class="star-wrapper">
            <div
              class="ReviewFormRating"
              style="
                display: flex;
                align-items: center;
                justify-content: center;
              "
              id="ratingStars"
            >
              {% for i in (1..5) %}
                <span class="form-star" data-value="{{ i }}">★</span>
              {% endfor %}
            </div>
            <input type="hidden" id="selectedRating" name="Rating" value="0">
            <span class="error-msg"></span>
          </div>
        </label>

        <!-- Name -->
        <label class="field-label ">
          Display Name
          <input
            name="Name"
            type="text"
            placeholder="Enter Your Name"
            value="{{ block.settings.display_name_text }}"
            class="input-field"
            id="formName"
          >
          <span class="error-msg"></span>
        </label>

        <!-- Email -->
        <label class="field-label">
          Email
          <input
            name="Email"
            type="text"
            placeholder="Enter Your Email"
            value="{{ block.settings.User_email }}"
            class="input-field"
            id="formEmail"
          >
          <span class="error-msg"></span>
        </label>

        <!-- Description -->
        <label class="field-label">
          Description
          <textarea
            name="Discription"
            placeholder="Write your review here ... "
            class="textarea-field"
            id="formDesc"
          >{{ block.settings.textarea_text }}</textarea>
          <span class="error-msg"></span>
        </label>

        <button type="submit" class="submit-btn button jm-write" id="submitButton">Submit</button>
      </form>
    </div>
  </div>
</div>
{% schema %}
{
  "name": "ReviewWidget",
  "target": "section",

  "settings": [
    {
      "type": "select",
      "id": "review_source",
      "label": "Review Source",
      "default": "dummy",
      "options": [
        {
          "value": "dummy",
          "label": "sample Data"
        },
        {
          "value": "real",
          "label": "Real Data"
        },
        {
          "value": "noReview",
          "label": "No Review"
        }
      ]
    },

    {
      "type": "checkbox",
      "id": "show_date",
      "label": "Show Date",
      "default": false
    },
    {
      "type": "text",
      "id": "textarea_text",
      "label": "Textarea Placeholder"
    },

    {
      "type": "text",
      "id": "display_name_text",
      "label": "Display name placeholder"
    },
    {
      "type": "text",
      "id": "User_email",
      "label": "Email text "
    }
  ]
}
{% endschema %}
