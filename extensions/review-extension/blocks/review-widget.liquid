    { "type": "textarea", "id": "review_2_text", "label": "Review Text" },
    {
      "type": "range",
      "id": "review_2_rating",
      "label": "Star Rating",
      "min": 1,
      "max": 5,
      "default": 5
    },

    /* --- REVIEW 3 --- */
    { "type": "header", "content": "Review 3" },
    { "type": "text", "id": "review_3_author", "label": "Author" },
    { "type": "textarea", "id": "review_3_text", "label": "Review Text" },
    {
      "type": "range",
      "id": "review_3_rating",
      "label": "Star Rating",
      "min": 1,
      "max": 5,
      "default": 5
    },

    /* --- REVIEW 4 --- */
    { "type": "header", "content": "Review 4" },
    { "type": "text", "id": "review_4_author", "label": "Author" },
    { "type": "textarea", "id": "review_4_text", "label": "Review Text" },
    {
      "type": "range",
      "id": "review_4_rating",
      "label": "Star Rating",
      "min": 1,
      "max": 5,
      "default": 5
    },

    /* --- REVIEW 5 --- */
    { "type": "header", "content": "Review 5" },
    { "type": "text", "id": "review_5_author", "label": "Author" },
    { "type": "textarea", "id": "review_5_text", "label": "Review Text" },
    {
      "type": "range",
      "id": "review_5_rating",
      "label": "Star Rating",
      "min": 1,
      "max": 5,
      "default": 2
    }
  ]
}
{% endschema %}
