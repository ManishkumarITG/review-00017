{{ 'review.css' | asset_url | stylesheet_tag }}
<script src="{{ 'review.js' | asset_url }}" defer></script>
{% comment %} <script src="{{ 'reviewFilter.js' | asset_url }}" defer></script> {% endcomment %}
{% comment %}
  <script>
    // Expose Liquid variables to JS
    window.reviewConfig = {
      reviewSource: "{{ block.settings.review_source }}",
         reviews: {{ reviews | json }},
      sortedReviews: {{ sorted | json }}
    };
  </script>
{% endcomment %}

<script>
  window.reviewSettings = {
    starColor: "{{ block.settings.star_color }}",
    textColor: "{{ block.settings.text_color }}",
    showDate: {{ block.settings.show_date }},
    reviewSource: "{{ block.settings.review_source }}"
  };
</script>

<script src="{{ 'reviewFilter.js' | asset_url }}" defer></script>

<script>
  function handleClick() {
    console.log('Enter in handleClick function');
    const errorEl = document.querySelector('.NoReviewerror-msg');
    const NoReviewSelectedRating = Number(document.getElementById('NoReviewSelectedRating')?.value || 0);
    {% comment %} const reviewSource = window.reviewConfig.reviewSource; {% endcomment %}
    console.log(errorEl, 'erriorEl');

    // Toggle the popup form
    const formDIV = document.getElementById('popupForm');
    if (!formDIV) {
      console.warn('popupForm missing in DOM');
      return;
    }

    formDIV.style.display = formDIV.style.display === 'block' ? 'none' : 'block';
  }
</script>

{% assign actual_rating = block.settings.actual_rating %}
{% assign progress_percent = count | times: 100.0 | divided_by: total_reviews %}

<div class="jm-review-widget my-review-widget" id="jm-review-{{ section.id }}">
  {% comment %} <!-- Header --> {% endcomment %}

  <div class="jm-list" id="jm-list-{{ section.id }}">
    <div
      style="
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 9px;
      "
    ></div>

    {% if block.settings.review_source == 'dummy' %}
      <div
        style="
          display: flex;
          flex-direction: column;
          align-items: center;
          gap: 9px;
        "
      >
        <h2
          class="jm-heading"
          style="
            color: {{ block.settings.heading_color }};
            font-size: {{ block.settings.heading_font }}px;
          "
        >
          {{ block.settings.heading }}
        </h2>
        <div>
          <div style=" align-items:center; gap:0px; flex-direction:row;">
            <span
              style="
                color: {{block.settings.star_color}};
                {% comment %} font-size: {{block.settings.star_size}}px; {% endcomment %}
                display:flex;
                gap:8px;
                align-items:center;
              "
            >
              {% render 'stars', rating: actual_rating %}
              <span style="font-weight:normal; color:black; font-size:14px;">{{ actual_rating }} out of 5</span>
            </span>
          </div>
          <span>Based on 15 reviews</span>
        </div>
        <div>
          {% assign star_counts = '8,3,1,3,0' | split: ',' %}
          {% assign total_reviews = 0 %}
          {% for c in star_counts %}
            {% assign total_reviews = total_reviews | plus: c %}
          {% endfor %}
          {% for i in (1..5) reversed %}
            {% assign index = forloop.index0 %}
            {% assign count = star_counts[index] | plus: 0 %}
            {% if total_reviews > 0 %}
              {% assign progress_percent = count | times: 100.0 | divided_by: total_reviews %}
            {% else %}
              {% assign progress_percent = 0 %}
            {% endif %}
            <div class="jm-Stars-Progressbar">
              {% comment %} <!-- LEFT: static stars (5 to 1) --> {% endcomment %}
              <span
                style="
                  color: {{ block.settings.star_color }};
                  font-size: {{ block.settings.star_size }}px;
                  width: 40%;
                  display:flex;
                "
              >
                {% render 'stars', rating: i %}
              </span>
              {% comment %} <!-- MIDDLE: progress bar --> {% endcomment %}
              <div style="background:#e5e7eb; height:14px; width:140px; border-radius:0px; overflow:hidden;">
                <div
                  style="
                    height:14px;
                    width:{{ progress_percent }}%;
                    background: {{ block.settings.star_color }};
                    border-radius:0px;
                  "
                ></div>
              </div>
              {% comment %} <!-- RIGHT: count --> {% endcomment %}
              <span style="color:#888888;">
                {{ count }}
              </span>
            </div>
          {% endfor %}
        </div>
      </div>
      <div class="jm-actions">
        <button
          class="jm-write"
          style="
            background: {{ block.settings.btn_bg }};
            color: {{ block.settings.btn_color }};
            border-radius: {{ block.settings.btn_radius }};
            padding: {{ block.settings.btn_padding }};
            font-size: {{ block.settings.btn_font_size }};
            margin: {{ block.settings.btn_margin }};
            width:100%
          "
          onclick="handleClick()"
        >
          Write a review
        </button>

        <div class="jm-sort">
          <select
            class="jm-sort-select"
            id="{{ block.settings.RatingFilter  }}"
            style="color:{{block.settings.star_color}}"
          >
            <option value="most_recent">Most Recent</option>
            <option value="highest">Highest Rating</option>
            <option value="lowest">Lowest Rating</option>
          </select>
        </div>
      </div>
      {%- comment -%} <!-- Dummy Reviews List --> {%- endcomment -%}
      {% comment %}
        {%- for i in (0..4) -%}
          {%- assign row = dummy_reviews[i] | split: '|' -%}
          {%- assign a = row[0] | strip -%}
          {%- assign b = row[1] | strip -%}
          {%- assign r = row[2] | strip -%}
          {%- assign d = row[3] | strip -%}
          <div class="jm-item">
            <div class="jm-item-left">
              <div style="color:{{block.settings.star_color}}" class="jm-avatar">{{ a | slice: 0, 1 }}</div>
            </div>
            <div class="jm-item-right">
              <div class="jm-topline">
                <div
                  class="jm-stars-inline"
                  style="
                    color: {{ block.settings.star_color }};
                    font-size: {{ block.settings.star_size }}px;
                    display:flex;
                    flex-direction:column;
                    align-items: flex-start;
                  "
                >
                  {% render 'stars', rating: r %}
                  <p style="color: {{ block.settings.star_color }}; margin:0px">{{ a }}</p>
                </div>
                {% if block.settings.show_date %}
                  <div>
                    <p>{{ d }}</p>
                  </div>
                {% endif %}
              </div>
              <div class="jm-body" style="color: {{ block.settings.text_color }};">
                <p>{{ b }}</p>
              </div>
            </div>
          </div>
        {% endfor %}
      {% endcomment %}
      <div id="reviewsList" style="display:flex; flex-direction:column; gap:18px; margin-top:20px;"></div>
    {% elsif block.settings.review_source == 'real' %}
      <div
        style="
          display: flex;
          flex-direction: column;
          align-items: center;
          gap: 9px;
        "
      >
        <h2
          class="jm-heading"
          style="
            color: {{ block.settings.heading_color }};
            font-size: {{ block.settings.heading_font }}px;
          "
        >
          {{ block.settings.heading }}
        </h2>
        <div>
          <div style=" align-items:center; gap:0px; flex-direction:row;">
            <span
              style="
                color: {{block.settings.star_color}};
                font-size: {{block.settings.star_size}}px;
                display:flex;
                gap:8px;
                align-items:center;
              "
            >
              {% render 'stars', rating: actual_rating %}
              <span style="font-weight:normal; color:black; font-size:14px;">{{ actual_rating }} out of 5</span>
            </span>
          </div>
          <span>Based on 15 reviews</span>
        </div>
        <div>
          {% assign star_counts = '8,3,1,3,0' | split: ',' %}
          {% assign total_reviews = 0 %}
          {% for c in star_counts %}
            {% assign total_reviews = total_reviews | plus: c %}
          {% endfor %}
          {% for i in (1..5) reversed %}
            {% assign index = forloop.index0 %}
            {% assign count = star_counts[index] | plus: 0 %}
            {% if total_reviews > 0 %}
              {% assign progress_percent = count | times: 100.0 | divided_by: total_reviews %}
            {% else %}
              {% assign progress_percent = 0 %}
            {% endif %}
            <div class="jm-Stars-Progressbar">
              {% comment %} <!-- LEFT: static stars (5 to 1) --> {% endcomment %}
              <span
                style="
                  color: {{ block.settings.star_color }};
                  font-size: {{ block.settings.star_size }}px;
                  width: 40%;
                  display:flex;
                "
              >
                {% render 'stars', rating: i %}
              </span>
              {% comment %} <!-- MIDDLE: progress bar --> {% endcomment %}
              <div style="background:#e5e7eb; height:14px; width:140px; border-radius:0px; overflow:hidden;">
                <div
                  style="
                    height:14px;
                    width:{{ progress_percent }}%;
                    background: {{ block.settings.star_color }};
                    border-radius:0px;
                  "
                ></div>
              </div>
              {% comment %} <!-- RIGHT: count --> {% endcomment %}
              <span style="color:#888888;">
                {{ count }}
              </span>
            </div>
          {% endfor %}
        </div>
      </div>
      <div class="jm-actions">
        <button
          class="jm-write"
          style="
            background: {{ block.settings.btn_bg }};
            color: {{ block.settings.btn_color }};
            border-radius: {{ block.settings.btn_radius }};
            padding: {{ block.settings.btn_padding }};
            font-size: {{ block.settings.btn_font_size }};
            margin: {{ block.settings.btn_margin }};
            width:100%
          "
          onclick="handleClick()"
        >
          Write a review
        </button>

        <div class="jm-sort">
          <select class="jm-sort-select" style="color:{{block.settings.star_color}}">
            <option value="most_recent">Most Recent</option>
            <option value="highest">Highest Rating</option>
            <option value="lowest">Lowest Rating</option>
          </select>
        </div>
      </div>
      <div id="reviewsList" style="display:flex; flex-direction:column; gap:18px; margin-top:20px;">
        {% comment %}
          {% for item in real_reviews %}
            {% assign row = item | split: '|' %}
            {% assign name = row[0] | strip %}
            {% assign rating = row[1] | strip %}
            {% assign text = row[2] | strip %}
            {% assign date = row[3] | strip %}

            <div
              style="
                display:flex; gap:14px; padding:16px;
                {% comment %} border:1px solid #e5e7eb;
                border-radius:12px; {% endcomment %}
                box-shadow:0 2px 8px rgba(0,0,0,0.04);
              "
            >
              {% comment %} <!-- Avatar --> {% endcomment %}
              <div
                class="jm-avatar"
                style="
                  color:{{ block.settings.star_color }};
                  font-size:18px;
                "
              >
                {{ name | slice: 0, 1 | upcase }}
              </div>

              <div style="flex:1;">
                <div style="display:flex; justify-content:space-between; align-items:center;">
                  <div>
                    <p style="margin:0; font-weight:600; color:{{block.settings.star_color}}">
                      {{ name }}
                    </p>
                    <div style="color:{{ block.settings.star_color }}; font-size:16px;">
                      {% render 'stars', rating: rating %}
                    </div>
                  </div>

                  {% if block.settings.show_date %}
                    <div>
                      <p style="margin:0; color:#888888;">{{ date }}</p>
                    </div>
                  {% endif %}
                </div>

                <p style="margin-top:10px; color:{{ block.settings.text_color }};">
                  {{ text }}
                </p>
              </div>
            </div>
          {% endfor %}
        {% endcomment %}
      </div>

    {% elsif block.settings.review_source == 'noReview' %}
      <div
        style="
                    display: flex;
          flex-direction: column;
          align-items: center;
          gap: 33px;
        "
      >
        <div>
          <h2
            class="jm-heading"
            style="
              color: {{ block.settings.heading_color }};
              font-size: {{ block.settings.heading_font }}px;
            "
          >
            {{ block.settings.heading }}
          </h2>
        </div>
        <div
          style="
            display: flex;
            justify-content: center;
            gap: 50px;
            align-items: center;
          "
        >
          <div
            style="
                     display: flex;
              align-items: self-start;
              flex-direction: column;
            "
          >
            <div>
              {% for i in (1..5) %}
                <span
                  class="form-star"
                  style="
                    font-size:20px;
                    color:#ccc;
                    cursor:pointer;
                  "
                  >★</span
                >
              {% endfor %}
            </div>
            <span>Be the first to write a review</span>
          </div>

          <div>
            <button
              class="jm-write"
              style="
                background: {{ block.settings.button_color }};
                color: {{ block.settings.button_text_color }};
              "
              onclick="handleClick()"
            >
              Write a review
            </button>
          </div>
        </div>
      </div>

    {% else %}
      {% comment %} <!-- Fallback (only if some wild unknown value appears) --> {% endcomment %}
      <div class="jm-db-placeholder">
        <span
          style="
            color: {{block.settings.star_color}};
            font-size: {{block.settings.star_size}}px;
          "
        >
          {% render 'stars', rating: 5 %}
        </span>
        <button
          class="jm-write"
          style="
            background: {{ block.settings.button_color }};
            color: {{ block.settings.button_text_color }};
          "
          onclick="handleClick()"
        >
          Write a review
        </button>
      </div>
    {% endif %}
  </div>
  <div
    id="popupForm"
    style="
      display:none;
      max-width:100%;
      margin:20px 20px;
      padding:24px;
      background:#fff;
      border-radius:16px;
      box-shadow:0 6px 20px rgba(0,0,0,0.08);
      font-family:Arial, sans-serif;
      border: 1px solid {{ block.settings.form_border_color }};
      align-items:center;
    "
  >
    <form id="reviewForm" style="padding:20px">
      {% comment %} <!-- Star Rating --> {% endcomment %}
      <div
        style="
          display: flex;
          flex-direction: column;
          align-items: center;
        "
      >
        <label
          style="
            font-size:{{block.settings.label_font_size}}px;
            font-weight:{{block.settings.label_font_weight}};
            color:{{block.settings.label_text_color}};
             display: flex;
            flex-direction: column;
            gap: 10px;
          "
        >
          {{ block.settings.star_label }}
          <div id="formStars" style="display:flex; gap:4px; flex-direction:column; ">
            <div>
              {% for i in (1..5) %}
                <span
                  class="form-star"
                  data-value="{{ i }}"
                  style="
                    font-size:60px;
                    color:#ccc;
                    cursor:pointer;
                  "
                  >★</span
                >
              {% endfor %}
            </div>

            <input type="hidden" id="selectedRating" name="Rating" value="0">
            <span class="error-msg"></span>
          </div>
        </label>
      </div>
      {% comment %} <!-- Display Name --> {% endcomment %}
      <label
        style="
                font-size:{{block.settings.label_font_size}}px;
                font-weight:{{block.settings.label_font_weight}};
                color:{{block.settings.label_text_color}};
                    display: flex;
          flex-direction: column;
          gap: 10px;
        "
      >
        {{ block.settings.display_name_label }}

        <input
          name="Name"
          type="text"
          placeholder="Enter Your Name"
          value="{{ block.settings.display_name_text }}"
          style="
            width:100%;
            padding:10px 12px;
            border:1px solid {{ block.settings.border_color }};
            border-radius: {{ block.settings.border_radius }}px;
            margin-bottom:5px;
            font-size:12px;
          "
        >
        <span class="error-msg"></span>
      </label>
      {% comment %} <!-- Email --> {% endcomment %}
      <label
        style="
          font-size:{{block.settings.label_font_size}}px;
          font-weight:{{block.settings.label_font_weight}};
          color:{{block.settings.label_text_color}};
          display: flex;
          flex-direction: column;
          gap: 10px;
        "
      >
        {{ block.settings.email_label }}
        <input
          name="Email"
          type="text"
          placeholder="Enter Your Email"
          value="{{ block.settings.User_email }}"
          style="
            width:100%;
            padding:10px 12px;
            border:1px solid {{ block.settings.border_color }};
            border-radius: {{ block.settings.border_radius }}px;
            margin-bottom:16px;
            font-size:14px;
          "
        >
        <span class="error-msg"></span>
      </label>

      {% comment %} <!-- Description --> {% endcomment %}
      <label
        style="
          font-size:{{block.settings.label_font_size}}px;
          font-weight:{{block.settings.label_font_weight}};
          color:{{block.settings.label_text_color}};
          display:flex;
          flex-direction: column;
          gap: 10px;
        "
      >
        {{ block.settings.description_label }}
        <textarea
          name="Discription"
          placeholder="{{ block.settings.description_placeholder }}"
          style="
            width:100%;
            min-height:100px;
            border:1px solid {{ block.settings.border_color }};
            padding:10px 12px;
            font-size:14px;
            resize:vertical;
            border-radius: {{ block.settings.border_radius }}px;
            margin-bottom:16px;
          "
        >{{ block.settings.textarea_text }}</textarea>
        <span class="error-msg"></span>
      </label>

      {% comment %} <!-- Submit Button --> {% endcomment %}
      <button
        type="submit"
        style="
          width:100%;
          margin-top:16px;
          padding:12px 0;
          border:none;
          border-radius:10px;
          background: {{ block.settings.star_color }};
          color: {{ block.settings.form_button_text_color }};
          font-size:15px;
          font-weight:600;
          cursor:pointer;
        "
      >
        {{ block.settings.submit_text }}
      </button>
    </form>
  </div>
</div>

{% schema %}
{
  "name": "ReviewWidget",
  "target": "section",

  "settings": [
    {
      "type": "select",
      "id": "review_source",
      "label": "Review Source",
      "default": "dummy",
      "options": [
        {
          "value": "dummy",
          "label": "sample Data"
        },
        {
          "value": "real",
          "label": "Real Data"
        },
        {
          "value": "noReview",
          "label": "No Review"
        }
      ]
    },

    {
      "type": "number",
      "id": "star_size",
      "label": "Star Size",
      "default": 24
    },
    {
      "type": "number",
      "id": "actual_rating",
      "label": "Actual Rating",
      "default": 5
    },
    {
      "type": "color",
      "id": "star_color",
      "label": "Star color",
      "default": "#108474"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Customer Reviews"
    },
    {
      "type": "color",
      "id": "heading_color",
      "label": "Heading color",
      "default": "#2a2a2a"
    },
    {
      "type": "range",
      "id": "heading_font",
      "label": "Heading font size",
      "default": 22,
      "min": 12,
      "max": 48
    },

    {
      "type": "color",
      "id": "text_color",
      "label": "Review text color",
      "default": "#333333"
    },

    {
      "type": "color",
      "id": "button_color",
      "label": "Write button color",
      "default": "#108474"
    },
    {
      "type": "color",
      "id": "button_text_color",
      "label": "Write button text color",
      "default": "#ffffff"
    },
    {
      "type": "text",
      "id": "write_review_button_width",
      "label": "Button Width",
      "default": "50%"
    },
    {
      "type": "checkbox",
      "id": "show_date",
      "label": "Show Date",
      "default": false
    },
    {
      "type": "color",
      "id": "btn_bg",
      "label": "Button Background Color",
      "default": "#108474"
    },
    {
      "type": "color",
      "id": "btn_color",
      "label": "Button Text Color",
      "default": "#ffffff"
    },
    {
      "type": "range",
      "id": "btn_radius",
      "label": "Border Radius",
      "min": 0,
      "max": 50,
      "default": 5,
      "unit": "px"
    },
    {
      "type": "text",
      "id": "btn_padding",
      "label": "Padding",
      "default": "10px 20px"
    },
    {
      "type": "range",
      "id": "btn_font_size",
      "label": "Font Size",
      "min": 10,
      "max": 40,
      "default": 14,
      "unit": "px"
    },

    {
      "type": "text",
      "id": "btn_margin",
      "label": "Margin",
      "default": "10px 0"
    },
    {
      "type": "text",
      "id": "label_font_size",
      "label": "Label Font Size",
      "default": "10px"
    },
    {
      "type": "text",
      "id": "label_font_weight",
      "label": "Label Font Weight",
      "default": "400"
    },
    {
      "type": "color",
      "id": "label_text_color",
      "label": "Label Font Colour",
      "default": "#108474"
    },
    {
      "type": "text",
      "id": "textarea_text",
      "label": "Textarea Placeholder"
    },
    {
      "type": "color",
      "id": "form_button_text_color",
      "label": "Button Text Color",
      "default": "#ffffff"
    },
    {
      "type": "text",
      "id": "submit_text",
      "label": "Submit Button Text",
      "default": "Submit"
    },
    {
      "type": "color",
      "id": "border_color",
      "label": "Textarea Border Color",
      "default": "#108474"
    },
    {
      "type": "range",
      "id": "border_radius",
      "label": "Border Radius",
      "min": 0,
      "max": 20,
      "step": 1,
      "default": 10,
      "unit": "px"
    },
    {
      "type": "text",
      "id": "display_name_label",
      "label": "Display name label",
      "default": "Display Name"
    },
    {
      "type": "text",
      "id": "display_name_text",
      "label": "Display name placeholder"
    },
    {
      "type": "text",
      "id": "email_label",
      "label": "Email label",
      "default": "Email"
    },
    {
      "type": "text",
      "id": "User_email",
      "label": "Email text "
    },
    {
      "type": "text",
      "id": "description_label",
      "label": "Description label",
      "default": "Description"
    },
    {
      "type": "text",
      "id": "description_placeholder",
      "label": "Description placeholder",
      "default": "Write your review here ... "
    },
    {
      "type": "text",
      "id": "star_label",
      "label": "Star Label",
      "default": "Rate the product"
    },
    {
      "type": "color",
      "id": "form_border_color",
      "label": "Form Border",
      "default": "transparent"
    }
  ]
}
{% endschema %}
