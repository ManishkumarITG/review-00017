              id="ratingStars"
            >
              {% for i in (1..5) %}
                <span class="form-star" data-value="{{ i }}">★</span>
              {% endfor %}
            </div>
            <input type="hidden" id="selectedRating" name="Rating" value="0">
            <span class="error-msg"></span>
          </div>
        </label>

        <!-- Name -->
        <label class="field-label ">
          Display Name
          <input
            name="Name"
            type="text"
            placeholder="Enter Your Name"
            class="input-field"
            id="formName"
          >
          <span class="error-msg"></span>
        </label>

        <!-- Email -->
        <label class="field-label">
          Email
          <input
            name="Email"
            type="text"
            placeholder="Enter Your Email"
            class="input-field"
            id="formEmail"
          >
          <span class="error-msg"></span>
        </label>

        <!-- Description -->
        <label class="field-label">
          Description
          <textarea
            name="Discription"
            placeholder="Write your review here ... "
            class="textarea-field"
            id="formDesc"
          ></textarea>
          <span class="error-msg"></span>
        </label>

        <button type="submit" class="submit-btn button jm-write" id="submitButton">Submit</button>
      </form>
    </div>
  </div>
</div>
{% schema %}
{
  "name": "ReviewWidget",
  "target": "section",

  "settings": [
    {
      "type": "select",
      "id": "review_source",
      "label": "Review Source",
      "default": "dummy",
      "options": [
        {
          "value": "dummy",
          "label": "sample Data"
        },
        {
          "value": "real",
          "label": "Real Data"
        },
        {
          "value": "noReview",
          "label": "No Review"
        }
      ]
    },

    {
      "type": "checkbox",
      "id": "show_date",
      "label": "Show Date",
      "default": false
    },

  ]
}
{% endschema %}
