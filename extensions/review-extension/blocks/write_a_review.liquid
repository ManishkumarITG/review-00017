<button
  style="
    background: {{ block.settings.btn_bg }};
    color: {{ block.settings.btn_text }};
    border-radius: {{ block.settings.btn_radius }};
    padding: {{ block.settings.btn_padding }};
    font-size: {{ block.settings.btn_font_size }};
    margin: {{ block.settings.btn_margin }};
    display: {{ block.settings.btn_display }};
    text-align: {{ block.settings.btn_align }};
    position: {{ block.settings.btn_position }};
    top: {{ block.settings.btn_top }};
    right: {{ block.settings.btn_right }};
    bottom: {{ block.settings.btn_bottom }};
    left: {{ block.settings.btn_left }};
  "
>
  {{ block.settings.button_label }}
</button>




{% schema %}
{
  "name": "Write a Review",
  "target": "section",
  "settings": [
    {
      "type": "text",
      "id": "button_label",
      "label": "Button Label",
      "default": "Write a Review"
    },

    /* Colors */
    {
      "type": "color",
      "id": "btn_bg",
      "label": "Button Background Color",
      "default": "#108474"
    },
    {
      "type": "color",
      "id": "btn_text",
      "label": "Button Text Color",
      "default": "#ffffff"
    },

    /* Basic CSS */
    {
      "type": "text",
      "id": "btn_radius",
      "label": "Border Radius",
      "default": "5px"
    },
    {
      "type": "text",
      "id": "btn_padding",
      "label": "Padding",
      "default": "10px 20px"
    },
    {
      "type": "text",
      "id": "btn_font_size",
      "label": "Font Size",
      "default": "14px"
    },

    /* Alignment */
    {
      "type": "select",
      "id": "btn_align",
      "label": "Text Alignment",
      "default": "center",
      "options": [
        { "value": "left", "label": "Left" },
        { "value": "center", "label": "Center" },
        { "value": "right", "label": "Right" }
      ]
    },
    {
      "type": "select",
      "id": "btn_display",
      "label": "Display",
      "default": "inline-block",
      "options": [
        { "value": "inline", "label": "Inline" },
        { "value": "inline-block", "label": "Inline Block" },
        { "value": "block", "label": "Block" }
      ]
    },

    /* Position */
    {
      "type": "select",
      "id": "btn_position",
      "label": "Button Position",
      "default": "static",
      "options": [
        { "value": "static", "label": "Static" },
        { "value": "relative", "label": "Relative" },
        { "value": "absolute", "label": "Absolute" },
        { "value": "fixed", "label": "Fixed" }
      ]
    },

    /* Position Offsets */
    {
      "type": "text",
      "id": "btn_top",
      "label": "Top",
      "default": "auto"
    },
    {
      "type": "text",
      "id": "btn_right",
      "label": "Right",
      "default": "auto"
    },
    {
      "type": "text",
      "id": "btn_bottom",
      "label": "Bottom",
      "default": "auto"
    },
    {
      "type": "text",
      "id": "btn_left",
      "label": "Left",
      "default": "auto"
    },

    /* Margin */
    {
      "type": "text",
      "id": "btn_margin",
      "label": "Margin",
      "default": "10px 0"
    }
  ]
}


{% endschema %}
